# Compiled binaries — produced by `go build` and `make build`
/bin/
/inkwell

# Test artifacts
*.test
*.out
coverage.txt

# SQLite databases (we'll have these from M2 onward)
*.db
*.db-journal
*.db-wal
*.db-shm

# Local config & feed lists (personal data — never commit).
# Real config lives in ~/.config/inkwell/; these guard test copies dropped
# in the repo. config.yaml leaks your vault_path; *.opml is your literal
# subscription list (M4 OPML import).
config.yaml
config.local.yaml
*.opml

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp

# Local-only env (we use a real config file, not dotenv, but just in case)
.env
.env.*
!.env.example
